# Ignore all node_modules folders recursively
**/node_modules/

# Ignore build folders
**/dist/
**/build/

# Ignore all environment files
**/.env
**/.env.*.local
.env.production

# Logs
**/npm-debug.log*
**/yarn-debug.log*
**/pnpm-debug.log*

# System files
.DS_Store
Thumbs.db

# IDE/editor configs
.vscode/
.idea/

# TypeScript cache (if applicable)
**/*.tsbuildinfo
