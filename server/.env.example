# Database Configuration
MONGO_URI=mongodb://localhost:27017/pharmatrace

# JWT Configuration
JWT_SECRET=your-jwt-secret-here

# Blockchain Configuration
BLOCKCHAIN_RPC=https://sepolia.infura.io/v3/your-infura-project-id
PRIVATE_KEY=your-private-key-here
PRODUCT_CONTRACT_ADDRESS=your-product-contract-address
BATCH_CONTRACT_ADDRESS=your-batch-contract-address
USER_CONTRACT_ADDRESS=your-user-contract-address

# Gmail Email Configuration
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_PASS=your-app-specific-password

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Server Configuration
PORT=3000
NODE_ENV=development