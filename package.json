  "devDependencies": {
    "concurrently": "^9.1.2",
    "hardhat": "^3.0.7",
    "nodemon": "^3.1.10"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
